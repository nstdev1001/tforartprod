{
  "hosting": {
    "predeploy": ["npm run build"],
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/weather",
        "function": {
          "functionId": "weather",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/api/chat",
        "function": {
          "functionId": "chat",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "/api/gold",
        "function": {
          "functionId": "gold",
          "region": "asia-southeast1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "header": [
    {
      "source": "/videos/**",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
